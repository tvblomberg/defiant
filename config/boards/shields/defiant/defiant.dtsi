#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix-transform = &default_transform;
        zmk,physical-layout = &default_layout;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";

        // Rows (inputs, with pull-down): P21 (top), P20 (home), P19 (bottom), P9 (side), P10 (thumb)
        row-gpios
            = <&gpio0 31 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // P21 - top row
            , <&gpio0 29 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // P20 - home row
            , <&gpio0 2  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // P19 - bottom row
            , <&gpio1 6  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // P9  - side key row
            , <&gpio0 9  (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>  // P10 - thumb row
            ;
    };

    default_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <5>;
        // Matrix map (in keymap array order):
        //   L pinky  L ring  L mid  L idx  L inner | R inner  R idx  R mid  R ring  R pinky
        // Row 0: top row (5 L + 5 R = 10 keys)
        // Row 1: home row (10 keys)
        // Row 2: bottom row (10 keys)
        // Row 3: side keys — L side (col 0), R side (col 9) — 2 keys
        // Row 4: thumbs — L thumb_near, L thumb_far, R thumb_far, R thumb_near — 4 keys
        //
        // Right half uses reversed col-gpios + col-offset=5 so its scan col 0 (P4)
        // maps to logical col 5 (R inner), and its scan col 4 (P0) maps to logical
        // col 9 (R pinky). This mirrors the flipped PCB physical layout.
        map = <
RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)   RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)   RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)   RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
RC(3,0)                                                                   RC(3,9)
                        RC(4,3) RC(4,4)   RC(4,5) RC(4,6)
        >;
    };

    default_layout: default_layout {
        compatible = "zmk,physical-layout";
        display-name = "Defiant";
        transform = <&default_transform>;
        kscan = <&kscan0>;
        // Key positions in matrix-transform map order (36 keys)
        keys  //                     w   h    x    y     rot    rx   ry
            // Row 0 (top)
            = <&key_physical_attrs 100 100  100   43       0     0    0>  // L pinky top
            , <&key_physical_attrs 100 100  200   18       0     0    0>  // L ring top
            , <&key_physical_attrs 100 100  300    0       0     0    0>  // L middle top
            , <&key_physical_attrs 100 100  400   38       0     0    0>  // L index top
            , <&key_physical_attrs 100 100  500   63       0     0    0>  // L inner top
            , <&key_physical_attrs 100 100 1182   63       0     0    0>  // R inner top
            , <&key_physical_attrs 100 100 1282   38       0     0    0>  // R index top
            , <&key_physical_attrs 100 100 1382    0       0     0    0>  // R middle top
            , <&key_physical_attrs 100 100 1482   18       0     0    0>  // R ring top
            , <&key_physical_attrs 100 100 1582   43       0     0    0>  // R pinky top
            // Row 1 (home)
            , <&key_physical_attrs 100 100  100  143       0     0    0>  // L pinky home
            , <&key_physical_attrs 100 100  200  118       0     0    0>  // L ring home
            , <&key_physical_attrs 100 100  300  100       0     0    0>  // L middle home
            , <&key_physical_attrs 100 100  400  138       0     0    0>  // L index home
            , <&key_physical_attrs 100 100  500  163       0     0    0>  // L inner home
            , <&key_physical_attrs 100 100 1182  163       0     0    0>  // R inner home
            , <&key_physical_attrs 100 100 1282  138       0     0    0>  // R index home
            , <&key_physical_attrs 100 100 1382  100       0     0    0>  // R middle home
            , <&key_physical_attrs 100 100 1482  118       0     0    0>  // R ring home
            , <&key_physical_attrs 100 100 1582  143       0     0    0>  // R pinky home
            // Row 2 (bottom)
            , <&key_physical_attrs 100 100  100  243       0     0    0>  // L pinky bottom
            , <&key_physical_attrs 100 100  200  218       0     0    0>  // L ring bottom
            , <&key_physical_attrs 100 100  300  200       0     0    0>  // L middle bottom
            , <&key_physical_attrs 100 100  400  238       0     0    0>  // L index bottom
            , <&key_physical_attrs 100 100  500  263       0     0    0>  // L inner bottom
            , <&key_physical_attrs 100 100 1182  263       0     0    0>  // R inner bottom
            , <&key_physical_attrs 100 100 1282  238       0     0    0>  // R index bottom
            , <&key_physical_attrs 100 100 1382  200       0     0    0>  // R middle bottom
            , <&key_physical_attrs 100 100 1482  218       0     0    0>  // R ring bottom
            , <&key_physical_attrs 100 100 1582  243       0     0    0>  // R pinky bottom
            // Row 3 (side keys)
            , <&key_physical_attrs 100 100    0  143       0     0    0>  // L side (outer pinky)
            , <&key_physical_attrs 100 100 1682  143       0     0    0>  // R side (outer pinky)
            // Row 4 (thumbs) — rotations in hundredths of a degree
            , <&key_physical_attrs 100 100  516  384  (-3000)  566  434>  // L thumb near
            , <&key_physical_attrs 100 150  591  439  (-3000)  641  514>  // L thumb far (1.5u tall)
            , <&key_physical_attrs 100 150 1091  439    3000  1141  514>  // R thumb far (1.5u tall)
            , <&key_physical_attrs 100 100 1166  384    3000  1216  434>  // R thumb near
            ;
    };
};
